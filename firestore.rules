rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.uid == '2cwK3E4SSvezZRop3VE14lbfJdc2' ||
         request.auth.token.email == 'vivekdalvi147@gmail.com' ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= minLen && 
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) || 
             request.resource.data[field] == null ||
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= minLen && 
              request.resource.data[field].size() <= maxLen);
    }

    function isValidNumber(field, minVal, maxVal) {
      return !(field in request.resource.data) || 
             request.resource.data[field] == null ||
             (request.resource.data[field] is number && 
              request.resource.data[field] >= minVal && 
              request.resource.data[field] <= maxVal);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isRecent(ts) {
      return ts is timestamp && 
             ts > request.time - duration.value(5, 'm') && 
             ts < request.time + duration.value(5, 'm');
    }

    function isValidRequest(data) {
      return hasRequiredFields(['userId', 'prompt', 'status', 'createdAt']) &&
             hasOnlyAllowedFields(['userId', 'userEmail', 'userIp', 'prompt', 'enhancedPrompt', 'referenceImageUrl', 'status', 'createdAt', 'imageUrl', 'error', 'completedAt', 'durationMs']) &&
             data.userId is string && data.userId.size() <= 128 &&
             isValidOptionalString('userEmail', 0, 255) &&
             isValidOptionalString('userIp', 0, 45) &&
             isValidString('prompt', 1, 5000) &&
             isValidOptionalString('enhancedPrompt', 0, 10000) &&
             isValidOptionalString('referenceImageUrl', 0, 2000) &&
             data.status in ['active', 'completed', 'error'] &&
             isRecent(data.createdAt) &&
             isValidOptionalString('imageUrl', 0, 2000) &&
             isValidOptionalString('error', 0, 1000) &&
             isValidNumber('durationMs', 0, 3600000);
    }

    function isValidGeneration(data) {
      return hasRequiredFields(['userId', 'prompt', 'imageUrl', 'createdAt']) &&
             hasOnlyAllowedFields(['userId', 'prompt', 'imageUrl', 'referenceImageUrl', 'size', 'createdAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             isValidString('prompt', 1, 10000) &&
             isValidString('imageUrl', 1, 2000) &&
             isValidOptionalString('referenceImageUrl', 0, 2000) &&
             isValidOptionalString('size', 0, 50) &&
             isRecent(data.createdAt);
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email']) &&
             hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'lastLogin', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 255 &&
             isValidOptionalString('displayName', 0, 100) &&
             isValidOptionalString('photoURL', 0, 500) &&
             (!('role' in data) || data.role == null || data.role in ['admin', 'user']) &&
             (!('lastLogin' in data) || isRecent(data.lastLogin));
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /requests/{requestId} {
      // Anyone can create a request (even anonymous users, to track free generations)
      // But we validate the data strictly
      allow create: if isValidRequest(request.resource.data) && 
                      (request.resource.data.userId == 'anonymous' || isAuthenticated());
      
      // Only admin or the creator can read/update their own request
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous';
      
      allow update: if isValidRequest(request.resource.data) && 
                      (isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous');
      
      // Only admin can delete requests
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Admin can read all users, users can read their own profile
      allow read: if isAdmin() || isOwner(userId);
      
      // Users can write their own profile, but only admin can change roles
      allow create: if isValidUser(request.resource.data) && isOwner(userId) && 
                      (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isValidUser(request.resource.data) && 
                      (isAdmin() || (isOwner(userId) && 
                        (!('role' in request.resource.data) || 
                         !('role' in resource.data) || 
                         request.resource.data.role == resource.data.role)));
    }
    
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /examples/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /generations/{docId} {
      // Public gallery: anyone can read
      allow read: if true;
      allow create: if isValidGeneration(request.resource.data) && 
                      ((isAuthenticated() && request.auth.uid == request.resource.data.userId) || request.resource.data.userId == 'anonymous');
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous';
    }
  }
}
