rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Replace this with your actual Admin UID from Firebase Authentication
    // Example: return request.auth != null && request.auth.uid == 'YOUR_ADMIN_UID_HERE';
    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.email == 'vivekdalvi147@gmail.com' && request.auth.token.email_verified == true) ||
        request.auth.uid == '2cwK3E4SSvezZRop3VE14lbfJdc2'
      );
    }

    match /generations/{docId} {
      allow get: if true;
      allow list: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous';
      allow create: if (request.auth != null && request.auth.uid == request.resource.data.userId) || request.resource.data.userId == 'anonymous';
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId);
    }
    
    match /requests/{docId} {
      // Anyone can create a request
      allow create: if true;
      
      // Only admin or the creator can read/update
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous';
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous' || (request.auth == null && resource.data.userId == 'anonymous');
      
      // Only admin can delete
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Admin can read all users, users can read their own profile
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      
      // Users can write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /settings/{docId} {
      // Anyone can read settings (e.g., to check if maintenance mode is on)
      allow read: if true;
      
      // Only admin can write settings
      allow write: if isAdmin();
    }
    match /examples/{docId} {
      // Anyone can read examples
      allow read: if true;
      
      // Only admin can write examples
      allow write: if isAdmin();
    }
    
    match /ai_models/{docId} {
      // Anyone can read available models
      allow read: if true;
      
      // Only admin can manage models
      allow write: if isAdmin();
    }
  }
}
