rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.uid == 'YOUR_ADMIN_UID_HERE'); // Replace with your actual UID from Firebase Console
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= minLen && 
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= minLen && 
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidRequest(data) {
      return hasRequiredFields(['userId', 'prompt', 'status', 'createdAt']) &&
             hasOnlyAllowedFields(['userId', 'userEmail', 'userIp', 'prompt', 'enhancedPrompt', 'referenceImageUrl', 'status', 'createdAt', 'imageUrl', 'error']) &&
             data.userId is string &&
             isValidString('prompt', 1, 5000) &&
             isValidOptionalString('enhancedPrompt', 1, 10000) &&
             isValidOptionalString('referenceImageUrl', 1, 2000) &&
             data.status in ['active', 'completed', 'error'] &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /requests/{requestId} {
      // Anyone can create a request (even anonymous users, to track free generations)
      // But we validate the data strictly
      allow create: if isValidRequest(request.resource.data) && 
                      (request.resource.data.userId == 'anonymous' || isOwner(request.resource.data.userId));
      
      // Only admin or the creator can read/update their own request
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous';
      
      allow update: if isValidRequest(request.resource.data) && 
                      (isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous');
      
      // Only admin can delete requests
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Admin can read all users, users can read their own profile
      allow read: if isAdmin() || isOwner(userId);
      
      // Users can write their own profile, but only admin can change roles
      allow create: if isValidUser(request.resource.data) && isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isValidUser(request.resource.data) && 
                      (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }
    
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /examples/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /generations/{docId} {
      allow get: if true;
      allow list: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous';
      allow create: if (isAuthenticated() && request.auth.uid == request.resource.data.userId) || request.resource.data.userId == 'anonymous';
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId) || resource.data.userId == 'anonymous';
    }
  }
}
