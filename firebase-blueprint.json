{
  "entities": {
    "Request": {
      "title": "Request",
      "description": "A record of an image generation request.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who made the request."
        },
        "userEmail": {
          "type": "string",
          "description": "The email of the user who made the request."
        },
        "userIp": {
          "type": "string",
          "description": "The IP address of the user who made the request."
        },
        "prompt": {
          "type": "string",
          "description": "The original prompt provided by the user."
        },
        "enhancedPrompt": {
          "type": "string",
          "description": "The enhanced prompt generated by Bol-AI."
        },
        "referenceImageUrl": {
          "type": "string",
          "description": "The URL of the reference image used for image-to-image."
        },
        "status": {
          "type": "string",
          "description": "The status of the request (e.g., 'active', 'completed', 'error').",
          "enum": ["active", "completed", "error"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the request was created."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the generated image."
        },
        "durationMs": {
          "type": "number",
          "description": "The time taken to generate the image in milliseconds."
        },
        "error": {
          "type": "string",
          "description": "The error message if the generation failed."
        }
      },
      "required": ["userId", "prompt", "status", "createdAt"]
    },
    "Generation": {
      "title": "Generation",
      "description": "A record of a successful image generation.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user."
        },
        "prompt": {
          "type": "string",
          "description": "The prompt used for generation."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the generated image."
        },
        "referenceImageUrl": {
          "type": "string",
          "description": "The URL of the reference image."
        },
        "size": {
          "type": "string",
          "description": "The size of the generated image."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the generation was saved."
        }
      },
      "required": ["userId", "prompt", "imageUrl", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The UID of the user."
        },
        "email": {
          "type": "string",
          "description": "The email of the user."
        },
        "displayName": {
          "type": "string",
          "description": "The display name of the user."
        },
        "photoURL": {
          "type": "string",
          "description": "The photo URL of the user."
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp of the last login."
        },
        "role": {
          "type": "string",
          "description": "The role of the user (e.g., 'admin', 'user').",
          "enum": ["admin", "user"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user was created."
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "maintenanceMode": {
          "type": "number",
          "description": "0: Off, 1: Full, 2: Soft"
        },
        "isEnhanceEnabled": {
          "type": "boolean",
          "description": "Whether Bol-AI Enhance is enabled globally."
        },
        "isTxtToImgEnabled": {
          "type": "boolean",
          "description": "Whether Text-to-Image is enabled globally."
        },
        "isImgToImgEnabled": {
          "type": "boolean",
          "description": "Whether Image-to-Image is enabled globally."
        }
      }
    }
  },
  "firestore": {
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Collection of image generation requests."
    },
    "/generations/{docId}": {
      "schema": "Generation",
      "description": "Collection of successful image generations."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/settings/general": {
      "schema": "Settings",
      "description": "Global application settings."
    }
  }
}
